# ============================================================================
# Environment Configuration - Unique Theme Launcher
# ============================================================================
# Copy this file to .env.local and fill in your values
# ============================================================================

# ============================================================================
# Google Cloud Configuration (Optional - for Google Sign-In)
# ============================================================================
# Get these from https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=unique-theme-launcher
GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# ============================================================================
# Application Settings
# ============================================================================
# Debug mode (true/false)
DEBUG_MODE=true

# Log level: debug, info, warning, error
LOG_LEVEL=info

# Enable detailed logging
VERBOSE_LOGGING=false

# ============================================================================
# Detection Configuration
# ============================================================================
# Name detection priority order (comma-separated)
# Options: google, contacts, sms, device_owner, fallback
DETECTION_ORDER=google,contacts,sms,fallback

# Timeout for name detection (milliseconds)
DETECTION_TIMEOUT_MS=5000

# Fallback name if detection fails
FALLBACK_NAME=Toi

# ============================================================================
# UI Configuration
# ============================================================================
# Theme animation duration (milliseconds)
ANIMATION_DURATION_MS=500

# Color saturation level (0-100)
COLOR_SATURATION=80

# Color lightness level (0-100)
COLOR_LIGHTNESS=50

# Border radius multiplier
BORDER_RADIUS_MULTIPLIER=1.0

# ============================================================================
# Feature Flags
# ============================================================================
# Enable WhatsApp detection (future)
FEATURE_WHATSAPP_DETECTION=false

# Enable Telegram detection (future)
FEATURE_TELEGRAM_DETECTION=false

# Enable WiFi name detection
FEATURE_WIFI_DETECTION=true

# Enable multi-profile support (future)
FEATURE_MULTI_PROFILE=false

# ============================================================================
# Storage & Backup
# ============================================================================
# Enable local storage encryption
STORAGE_ENCRYPTION=true

# Enable backup to cloud (future)
CLOUD_BACKUP_ENABLED=false

# Cloud backup interval (minutes)
CLOUD_BACKUP_INTERVAL=60

# ============================================================================
# Analytics & Telemetry (Optional)
# ============================================================================
# Enable anonymous analytics
ANALYTICS_ENABLED=false

# Enable crash reporting
CRASH_REPORTING_ENABLED=false

# ============================================================================
# Build & Release Configuration
# ============================================================================
# Build variant: debug, profile, release
BUILD_VARIANT=debug

# Version (should match pubspec.yaml)
APP_VERSION=1.0.0

# Build number (should match pubspec.yaml)
BUILD_NUMBER=1

# Release channel: alpha, beta, stable
RELEASE_CHANNEL=beta
